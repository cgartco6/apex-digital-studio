# Server Configuration
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/apex-digital
REDIS_URL=redis://:password@redis-host:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORGANIZATION=org-your-org-id
OPENAI_ENDPOINT=https://your-openai-endpoint.openai.azure.com/  # if using Azure

# Stability AI (for image generation)
STABILITY_API_KEY=sk-your-stability-key

# Payment Gateways
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
PAYFAST_ENV=production

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENV=production

# South African Banking Details (for Direct EFT)
BANK_NAME=First National Bank
BANK_ACCOUNT_NUMBER=1234567890
BANK_ACCOUNT_NAME=Apex Digital Studio (Pty) Ltd
BANK_BRANCH_CODE=250655

# PayShap (if using)
PAYSHAP_MERCHANT_ID=your_payshap_id
PAYSHAP_API_KEY=your_payshap_key

# Email Service
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=Apex Digital Studio <noreply@apexdigital.studio>

# Cloudinary (for image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AWS S3 (for file storage, optional)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=af-south-1
AWS_BUCKET_NAME=apex-digital-studio
AWS_BUCKET_URL=https://apex-digital-studio.s3.af-south-1.amazonaws.com

# Analytics & Monitoring
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
MIXPANEL_TOKEN=your-mixpanel-token
SENTRY_DSN=your-sentry-dsn

# AI Model APIs (Replicate, etc.)
REPLICATE_API_TOKEN=r8_your_replicate_token

# Security
CORS_ORIGIN=https://yourdomain.com
HELMET_ENABLED=true
RATE_LIMITER_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_DIR=./logs

# Session (if using express-session)
SESSION_SECRET=your-session-secret
SESSION_MAX_AGE=86400000

# Queue (Bull)
REDIS_QUEUE_HOST=redis-host
REDIS_QUEUE_PORT=6379
REDIS_QUEUE_PASSWORD=your-redis-password
REDIS_QUEUE_DB=0

# WebSocket
WS_PORT=8080
WS_PATH=/socket.io

# API Version
API_VERSION=v1

# Payout Accounts (IDs will be set via admin UI)
# These are not stored in env but in DB – see PayoutAccount model.
